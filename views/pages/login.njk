{% extends "layouts/main.njk" %}

{% block content %}
<div class="w-full max-w-4xl overflow-hidden rounded-[1.75rem] glass-shell">
  <div class="grid md:grid-cols-2">
    <div
      class="relative hidden md:flex flex-col items-center justify-center text-center p-10 lg:p-12 glass-tint text-zinc-100 min-h-[28rem]">
      <img src="/logo.png" width="160" height="160" alt="Cartulaire"
        class="w-36 h-36 lg:w-40 lg:h-40 object-contain select-none" />
      <h1 class="mt-8 text-[2rem] lg:text-[2.25rem] font-semibold tracking-tight text-zinc-50 leading-tight">
        Bienvenue
      </h1>
      <p class="mt-4 text-[15px] leading-relaxed text-zinc-400 max-w-[280px]">
        Connexion sécurisée à votre espace.
      </p>
      <p class="mt-10 text-[11px] text-zinc-600">Authentification OIDC</p>
    </div>

    <div class="p-8 sm:p-10 lg:p-12 glass-inner backdrop-blur-sm">
      <div class="flex flex-col items-center md:items-start mb-8 md:mb-9">
        <img src="/logo.png" width="112" height="112" alt="" decoding="async"
          class="md:hidden w-24 h-24 object-contain select-none" />
        <div class="mt-6 md:mt-0 w-full text-center md:text-left md:flex md:items-center md:gap-4">
          <img src="/logo.png" width="112" height="112" alt="" decoding="async"
            class="hidden md:block shrink-0 w-14 h-14 object-contain select-none" />
          <div class="md:pt-0">
            <h2 class="text-2xl font-semibold tracking-tight text-zinc-50">Connexion</h2>
            <p class="mt-1.5 text-[15px] text-zinc-500">Saisissez vos identifiants</p>
          </div>
        </div>
      </div>

      {% if errorMessage %}
      <div class="mb-5 rounded-2xl border border-red-400/30 bg-red-500/10 px-4 py-3 text-sm text-red-200">
        {{ errorMessage }}
      </div>
      {% endif %}

      <form action="/interaction/{{ uid }}" method="POST" autocomplete="off" class="space-y-5">
        <div>
          <label for="username" class="block text-[13px] font-medium text-zinc-400 mb-2">Identifiant</label>
          <input type="text" name="username" id="username" value="{{ form.username | default('') }}" required
            class="glass-field block w-full rounded-2xl px-4 py-3 text-[15px] placeholder:text-zinc-600 transition" />
        </div>

        <div>
          <label for="password" class="block text-[13px] font-medium text-zinc-400 mb-2">Mot de passe</label>
          <input type="password" name="password" id="password" required
            class="glass-field block w-full rounded-2xl px-4 py-3 text-[15px] placeholder:text-zinc-600 transition" />
        </div>

        <div class="flex justify-end pt-0.5">
          <a href="/forgot-password" class="link-accent text-[13px] font-medium transition">
            Mot de passe oublié ?
          </a>
        </div>

        <button type="submit"
          class="btn-primary w-full rounded-full px-4 py-3.5 text-[15px] transition active:scale-[0.99]">
          Se connecter
        </button>

        <p class="text-center text-[13px] text-zinc-500 pt-2">
          Pas encore de compte ?
          <a href="/register" class="link-accent font-semibold transition">Créer un compte</a>
        </p>
      </form>
    </div>
  </div>
</div>
{% endblock %}
