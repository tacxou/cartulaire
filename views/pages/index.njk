{% extends "layouts/main.njk" %}

{% block head_extra %}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
<style>
  .page-index { font-family: 'Sora', sans-serif; }
  .page-index .bg-grid {
    background-image:
      linear-gradient(rgba(100,80,255,.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(100,80,255,.05) 1px, transparent 1px);
    background-size: 52px 52px;
  }
  .page-index .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
  }
  .page-index .glass {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.09);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
  .page-index .glass-strong {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.11);
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
  }
  .page-index .dot-live {
    animation: pulseDot 2s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%, 100% { opacity: 1; }
    50% { opacity: .3; }
  }
  .page-index .app-card {
    transition: transform .22s ease, border-color .22s ease, background .22s ease;
  }
  .page-index .app-card:hover {
    transform: translateY(-4px);
    border-color: rgba(124,58,237,.4) !important;
    background: rgba(124,58,237,.07) !important;
  }
  .page-index .text-gradient {
    background: linear-gradient(130deg, #c4b5fd 10%, #7c3aed 60%, #4c1d95);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
{% endblock %}

