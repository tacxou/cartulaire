{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "../views/**/*.njk",
        "outDir": "dist/views",
        "watchAssets": true
      },
      {
        "include": "../static/**/*",
        "outDir": "dist/static",
        "watchAssets": true
      },
      {
        "include": "../config/**/*.yml",
        "outDir": "dist/config",
        "watchAssets": true
      }
    ],
    "builder": "swc",
    "typeCheck": false,
    "watchAssets": true
  }
}
